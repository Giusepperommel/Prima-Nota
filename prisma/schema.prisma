generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Societa {
  id               Int      @id @default(autoincrement())
  ragioneSociale   String   @map("ragione_sociale") @db.VarChar(255)
  partitaIva       String   @unique @map("partita_iva") @db.VarChar(11)
  codiceFiscale    String   @map("codice_fiscale") @db.VarChar(16)
  indirizzo        String?  @db.Text
  tipoAttivita     TipoAttivita @default(SRL) @map("tipo_attivita")
  regimeFiscale    RegimeFiscale @default(ORDINARIO) @map("regime_fiscale")
  aliquotaIrap     Decimal  @default(3.90) @map("aliquota_irap") @db.Decimal(5, 2)
  capitaleSociale  Decimal? @map("capitale_sociale") @db.Decimal(12, 2)
  dataCostituzione DateTime? @map("data_costituzione") @db.Date
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  soci           Socio[]
  categorieSpesa CategoriaSpesa[]
  operazioni     Operazione[]
  cespiti        Cespite[]
  operazioniRicorrenti OperazioneRicorrente[]
  presetRipartizioni PresetRipartizione[]
  pianiPagamento     PianoPagamento[]

  @@map("societa")
}

model Socio {
  id                Int      @id @default(autoincrement())
  societaId         Int?     @map("societa_id")
  nome              String   @db.VarChar(100)
  cognome           String   @db.VarChar(100)
  codiceFiscale     String   @map("codice_fiscale") @db.VarChar(16)
  email             String   @unique @db.VarChar(255)
  quotaPercentuale  Decimal  @map("quota_percentuale") @db.Decimal(5, 2)
  ruolo             RuoloUtente @default(STANDARD)
  dataIngresso      DateTime? @map("data_ingresso") @db.Date
  attivo            Boolean  @default(true)
  socioLavoratore   Boolean  @default(false) @map("socio_lavoratore")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  societa              Societa? @relation(fields: [societaId], references: [id])
  utente               Utente?
  ripartizioniOperazione RipartizioneOperazione[]
  presetRipartizioni PresetRipartizioneSocio[]

  @@map("soci")
}

model Utente {
  id            Int       @id @default(autoincrement())
  socioId       Int       @unique @map("socio_id")
  email         String    @unique @db.VarChar(255)
  passwordHash  String    @map("password_hash") @db.VarChar(255)
  emailVerificata Boolean @default(false) @map("email_verificata")
  ultimoAccesso DateTime? @map("ultimo_accesso")
  createdAt     DateTime  @default(now()) @map("created_at")

  socio         Socio @relation(fields: [socioId], references: [id])
  operazioniCreate Operazione[]
  logAttivita   LogAttivita[]
  preferenzeUso PreferenzaUsoCategoria[]
  operazioniRicorrenti OperazioneRicorrente[]

  @@map("utenti")
}

model CategoriaSpesa {
  id                      Int      @id @default(autoincrement())
  societaId               Int      @map("societa_id")
  nome                    String   @db.VarChar(100)
  percentualeDeducibilita Decimal  @map("percentuale_deducibilita") @db.Decimal(5, 2)
  descrizione             String?  @db.Text
  tipoCategoria           String?  @map("tipo_categoria") @db.VarChar(50)
  aliquotaIvaDefault        Decimal  @default(22) @map("aliquota_iva_default") @db.Decimal(5, 2)
  percentualeDetraibilitaIva Decimal @default(100) @map("percentuale_detraibilita_iva") @db.Decimal(5, 2)
  haOpzioniUso              Boolean  @default(false) @map("ha_opzioni_uso")
  opzioniUso                Json?    @map("opzioni_uso")
  attiva                  Boolean  @default(true)
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  societa       Societa      @relation(fields: [societaId], references: [id])
  operazioni    Operazione[]
  preferenzeUso PreferenzaUsoCategoria[]
  operazioniRicorrenti OperazioneRicorrente[]

  @@map("categorie_spesa")
}

model Operazione {
  id                      Int              @id @default(autoincrement())
  societaId               Int              @map("societa_id")
  tipoOperazione          TipoOperazione   @map("tipo_operazione")
  dataOperazione          DateTime         @map("data_operazione") @db.Date
  numeroDocumento         String?          @map("numero_documento") @db.VarChar(50)
  descrizione             String           @db.Text
  importoTotale           Decimal          @map("importo_totale") @db.Decimal(10, 2)
  aliquotaIva             Decimal?         @map("aliquota_iva") @db.Decimal(5, 2)
  importoImponibile       Decimal?         @map("importo_imponibile") @db.Decimal(10, 2)
  importoIva              Decimal?         @map("importo_iva") @db.Decimal(10, 2)
  percentualeDetraibilitaIva Decimal?      @map("percentuale_detraibilita_iva") @db.Decimal(5, 2)
  ivaDetraibile              Decimal?      @map("iva_detraibile") @db.Decimal(10, 2)
  ivaIndetraibile            Decimal?      @map("iva_indetraibile") @db.Decimal(10, 2)
  opzioneUso                 String?       @map("opzione_uso") @db.VarChar(50)
  categoriaId          Int?     @map("categoria_id")
  sottotipoOperazione  String?  @map("sottotipo_operazione") @db.VarChar(50)
  importoDeducibile       Decimal          @map("importo_deducibile") @db.Decimal(10, 2)
  percentualeDeducibilita Decimal          @map("percentuale_deducibilita") @db.Decimal(5, 2)
  deducibilitaCustom      Boolean          @default(false) @map("deducibilita_custom")
  tipoRipartizione        TipoRipartizione @map("tipo_ripartizione")
  note                    String?          @db.Text
  fileAllegato            String?          @map("file_allegato") @db.VarChar(255)
  fileXml                 String?          @map("file_xml") @db.LongText
  eliminato               Boolean          @default(false)
  bozza                  Boolean  @default(false)
  operazioneRicorrenteId Int?     @map("operazione_ricorrente_id")
  createdByUserId         Int              @map("created_by_user_id")
  createdAt               DateTime         @default(now()) @map("created_at")
  updatedAt               DateTime         @updatedAt @map("updated_at")

  societa      Societa                  @relation(fields: [societaId], references: [id])
  categoria    CategoriaSpesa?          @relation(fields: [categoriaId], references: [id], onDelete: Restrict)
  createdBy    Utente                   @relation(fields: [createdByUserId], references: [id])
  ripartizioni RipartizioneOperazione[]
  cespite      Cespite?
  pianoPagamento PianoPagamento?
  operazioneRicorrente OperazioneRicorrente? @relation(fields: [operazioneRicorrenteId], references: [id])

  @@index([societaId, dataOperazione])
  @@index([categoriaId])
  @@index([createdByUserId])
  @@index([operazioneRicorrenteId])
  @@map("operazioni")
}

model RipartizioneOperazione {
  id               Int     @id @default(autoincrement())
  operazioneId     Int     @map("operazione_id")
  socioId          Int     @map("socio_id")
  percentuale      Decimal @db.Decimal(5, 2)
  importoCalcolato Decimal @map("importo_calcolato") @db.Decimal(10, 2)

  operazione Operazione @relation(fields: [operazioneId], references: [id], onDelete: Cascade)
  socio      Socio      @relation(fields: [socioId], references: [id])

  @@index([operazioneId])
  @@index([socioId])
  @@map("ripartizioni_operazione")
}

model PresetRipartizione {
  id            Int      @id @default(autoincrement())
  societaId     Int      @map("societa_id")
  nome          String   @db.VarChar(100)
  tipiOperazione Json    @map("tipi_operazione")
  ordinamento   Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  societa Societa @relation(fields: [societaId], references: [id])
  soci    PresetRipartizioneSocio[]

  @@index([societaId, ordinamento])
  @@map("preset_ripartizioni")
}

model PresetRipartizioneSocio {
  id                    Int     @id @default(autoincrement())
  presetRipartizioneId  Int     @map("preset_ripartizione_id")
  socioId               Int     @map("socio_id")
  percentuale           Decimal @db.Decimal(5, 2)

  preset PresetRipartizione @relation(fields: [presetRipartizioneId], references: [id], onDelete: Cascade)
  socio  Socio              @relation(fields: [socioId], references: [id])

  @@index([presetRipartizioneId])
  @@index([socioId])
  @@map("preset_ripartizioni_soci")
}

model LogAttivita {
  id          Int           @id @default(autoincrement())
  userId      Int           @map("user_id")
  azione      AzioneLog
  tabella     String        @db.VarChar(50)
  recordId    Int           @map("record_id")
  valoriPrima Json?         @map("valori_prima")
  valoriDopo  Json?         @map("valori_dopo")
  ipAddress   String?       @map("ip_address") @db.VarChar(45)
  timestamp   DateTime      @default(now())

  utente Utente @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tabella, recordId])
  @@index([timestamp])
  @@map("log_attivita")
}

model VerificaEmail {
  id         Int      @id @default(autoincrement())
  email      String   @db.VarChar(255)
  codice     String   @db.VarChar(5)
  scadenza   DateTime
  verificato Boolean  @default(false)
  tentativi  Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([email, verificato, scadenza])
  @@map("verifica_email")
}

model ResetPassword {
  id         Int      @id @default(autoincrement())
  email      String   @db.VarChar(255)
  codice     String   @db.VarChar(5)
  scadenza   DateTime
  utilizzato Boolean  @default(false)
  tentativi  Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([email, utilizzato, scadenza])
  @@map("reset_password")
}

enum RuoloUtente {
  ADMIN
  STANDARD
  SUPER_ADMIN

  @@map("ruolo_utente")
}

enum TipoOperazione {
  FATTURA_ATTIVA
  COSTO
  CESPITE
  PAGAMENTO_IMPOSTE
  DISTRIBUZIONE_DIVIDENDI
  COMPENSO_AMMINISTRATORE

  @@map("tipo_operazione")
}

enum TipoRipartizione {
  COMUNE
  SINGOLO
  CUSTOM

  @@map("tipo_ripartizione")
}

enum AzioneLog {
  INSERT
  UPDATE
  DELETE

  @@map("azione_log")
}

model Cespite {
  id                    Int           @id @default(autoincrement())
  operazioneId          Int           @unique @map("operazione_id")
  societaId             Int           @map("societa_id")
  descrizione           String        @db.Text
  valoreIniziale        Decimal       @map("valore_iniziale") @db.Decimal(10, 2)
  aliquotaAmmortamento  Decimal       @map("aliquota_ammortamento") @db.Decimal(5, 2)
  dataAcquisto          DateTime      @map("data_acquisto") @db.Date
  annoInizio            Int           @map("anno_inizio")
  stato                 StatoCespite  @default(IN_AMMORTAMENTO)
  fondoAmmortamento     Decimal       @default(0) @map("fondo_ammortamento") @db.Decimal(10, 2)
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  operazione        Operazione          @relation(fields: [operazioneId], references: [id])
  societa           Societa             @relation(fields: [societaId], references: [id])
  quoteAmmortamento QuotaAmmortamento[]
  veicolo           Veicolo?

  @@index([societaId])
  @@map("cespiti")
}

model QuotaAmmortamento {
  id                Int      @id @default(autoincrement())
  cespiteId         Int      @map("cespite_id")
  anno              Int
  aliquotaApplicata Decimal  @map("aliquota_applicata") @db.Decimal(5, 2)
  importoQuota      Decimal  @map("importo_quota") @db.Decimal(10, 2)
  fondoProgressivo  Decimal  @map("fondo_progressivo") @db.Decimal(10, 2)
  createdAt         DateTime @default(now()) @map("created_at")

  cespite Cespite @relation(fields: [cespiteId], references: [id], onDelete: Cascade)

  @@unique([cespiteId, anno])
  @@index([cespiteId])
  @@index([anno])
  @@map("quote_ammortamento")
}

enum StatoCespite {
  IN_AMMORTAMENTO
  COMPLETATO
  CEDUTO
}

enum TipoAttivita {
  SRL
  SRLS
  SNC
  SAS
  STP
  DITTA_INDIVIDUALE
  LIBERO_PROFESSIONISTA
  AGENTE_COMMERCIO

  @@map("tipo_attivita")
}

enum RegimeFiscale {
  ORDINARIO
  FORFETTARIO

  @@map("regime_fiscale")
}

enum TipoContratto {
  LEASING
  NOLEGGIO_LUNGO_TERMINE

  @@map("tipo_contratto")
}

enum TipoVeicolo {
  AUTOVETTURA
  MOTOCICLO
  CICLOMOTORE
  AUTOCARRO

  @@map("tipo_veicolo")
}

enum UsoVeicolo {
  PROMISCUO
  STRUMENTALE_ESCLUSIVO
  USO_DIPENDENTE
  AGENTE_COMMERCIO

  @@map("uso_veicolo")
}

enum ModalitaAcquisto {
  CONTANTI
  FINANZIAMENTO

  @@map("modalita_acquisto")
}

enum TipoPianoPagamento {
  RATEALE
  CUSTOM

  @@map("tipo_piano_pagamento")
}

enum StatoPianoPagamento {
  ATTIVO
  CHIUSO_ANTICIPATAMENTE
  COMPLETATO

  @@map("stato_piano_pagamento")
}

enum StatoPagamento {
  PREVISTO
  EFFETTUATO
  ANNULLATO

  @@map("stato_pagamento")
}

enum MotivoChiusura {
  ESTINZIONE_ANTICIPATA
  PERMUTA
  RIFINANZIAMENTO

  @@map("motivo_chiusura")
}

enum FrequenzaRate {
  MENSILE

  @@map("frequenza_rate")
}

model PreferenzaUsoCategoria {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  categoriaId Int      @map("categoria_id")
  opzioneUso  String   @map("opzione_uso") @db.VarChar(50)
  updatedAt   DateTime @updatedAt @map("updated_at")

  utente    Utente         @relation(fields: [userId], references: [id])
  categoria CategoriaSpesa @relation(fields: [categoriaId], references: [id])

  @@unique([userId, categoriaId])
  @@map("preferenze_uso_categoria")
}

model OperazioneRicorrente {
  id                Int       @id @default(autoincrement())
  societaId         Int       @map("societa_id")
  createdByUserId   Int       @map("created_by_user_id")
  attiva            Boolean   @default(true)

  // Template dati operazione
  tipoOperazione    TipoOperazione @map("tipo_operazione")
  // Note: PAGAMENTO_IMPOSTE / DISTRIBUZIONE_DIVIDENDI / COMPENSO_AMMINISTRATORE
  // are not supported as recurring operation types; categoriaId remains required here.
  categoriaId       Int            @map("categoria_id")
  descrizione       String         @db.Text
  importoTotale     Decimal        @map("importo_totale") @db.Decimal(10, 2)
  aliquotaIva       Decimal?       @map("aliquota_iva") @db.Decimal(5, 2)
  importoImponibile Decimal?       @map("importo_imponibile") @db.Decimal(10, 2)
  importoIva        Decimal?       @map("importo_iva") @db.Decimal(10, 2)
  percentualeDetraibilitaIva Decimal? @map("percentuale_detraibilita_iva") @db.Decimal(5, 2)
  ivaDetraibile     Decimal?       @map("iva_detraibile") @db.Decimal(10, 2)
  ivaIndetraibile   Decimal?       @map("iva_indetraibile") @db.Decimal(10, 2)
  opzioneUso        String?        @map("opzione_uso") @db.VarChar(50)
  percentualeDeducibilita Decimal  @map("percentuale_deducibilita") @db.Decimal(5, 2)
  importoDeducibile Decimal        @map("importo_deducibile") @db.Decimal(10, 2)
  deducibilitaCustom Boolean       @default(false) @map("deducibilita_custom")
  tipoRipartizione  TipoRipartizione @map("tipo_ripartizione")
  socioSingoloId    Int?           @map("socio_singolo_id")
  note              String?        @db.Text

  // Ricorrenza
  giornoDelMese        Int       @map("giorno_del_mese")
  dataInizio           DateTime  @map("data_inizio") @db.Date
  dataFine             DateTime? @map("data_fine") @db.Date
  prossimaGenerazione  DateTime  @map("prossima_generazione") @db.Date

  // Dati fiscali leasing/NLT (opzionali)
  tipoContratto     TipoContratto? @map("tipo_contratto")
  valoreBene        Decimal?       @map("valore_bene") @db.Decimal(10, 2)
  maxicanone        Decimal?       @map("maxicanone") @db.Decimal(10, 2)
  durataContratto   Int?           @map("durata_contratto")
  quotaServizi      Decimal?       @map("quota_servizi") @db.Decimal(10, 2)
  rateRimanenti     Int?           @map("rate_rimanenti")

  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  societa            Societa        @relation(fields: [societaId], references: [id])
  categoria          CategoriaSpesa @relation(fields: [categoriaId], references: [id])
  createdBy          Utente         @relation(fields: [createdByUserId], references: [id])
  operazioniGenerate Operazione[]
  finanziamenti     Finanziamento[]

  @@index([societaId, attiva])
  @@index([prossimaGenerazione])
  @@map("operazioni_ricorrenti")
}

model Veicolo {
  id                        Int              @id @default(autoincrement())
  cespiteId                 Int              @unique @map("cespite_id")
  tipoVeicolo               TipoVeicolo      @map("tipo_veicolo")
  usoVeicolo                UsoVeicolo       @map("uso_veicolo")
  modalitaAcquisto          ModalitaAcquisto @map("modalita_acquisto")
  marca                     String           @db.VarChar(100)
  modello                   String           @db.VarChar(100)
  targa                     String           @db.VarChar(20)
  limiteFiscale             Decimal          @map("limite_fiscale") @db.Decimal(10, 2)
  percentualeDeducibilita   Decimal          @map("percentuale_deducibilita") @db.Decimal(5, 2)
  percentualeDetraibilitaIva Decimal         @map("percentuale_detraibilita_iva") @db.Decimal(5, 2)
  createdAt                 DateTime         @default(now()) @map("created_at")
  updatedAt                 DateTime         @updatedAt @map("updated_at")

  cespite        Cespite          @relation(fields: [cespiteId], references: [id], onDelete: Cascade)
  finanziamento  Finanziamento?
  cessione       CessioneVeicolo?

  @@map("veicoli")
}

model Finanziamento {
  id                      Int       @id @default(autoincrement())
  veicoloId               Int       @unique @map("veicolo_id")
  importoFinanziato       Decimal   @map("importo_finanziato") @db.Decimal(10, 2)
  anticipo                Decimal   @default(0) @db.Decimal(10, 2)
  numeroRate              Int       @map("numero_rate")
  importoRata             Decimal   @map("importo_rata") @db.Decimal(10, 2)
  tan                     Decimal?  @db.Decimal(5, 2)
  dataPrimaRata           DateTime  @map("data_prima_rata") @db.Date
  operazioneRicorrenteId  Int?      @map("operazione_ricorrente_id")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  veicolo              Veicolo               @relation(fields: [veicoloId], references: [id], onDelete: Cascade)
  operazioneRicorrente OperazioneRicorrente? @relation(fields: [operazioneRicorrenteId], references: [id])

  @@map("finanziamenti")
}

model CessioneVeicolo {
  id                      Int      @id @default(autoincrement())
  veicoloId               Int      @unique @map("veicolo_id")
  dataCessione            DateTime @map("data_cessione") @db.Date
  prezzoVendita           Decimal  @map("prezzo_vendita") @db.Decimal(10, 2)
  valoreResiduoContabile  Decimal  @map("valore_residuo_contabile") @db.Decimal(10, 2)
  plusvalenza             Decimal  @default(0) @db.Decimal(10, 2)
  plusvalenzaImponibile   Decimal  @default(0) @map("plusvalenza_imponibile") @db.Decimal(10, 2)
  minusvalenza            Decimal  @default(0) @db.Decimal(10, 2)
  minusvalenzaDeducibile  Decimal  @default(0) @map("minusvalenza_deducibile") @db.Decimal(10, 2)
  createdAt               DateTime @default(now()) @map("created_at")

  veicolo Veicolo @relation(fields: [veicoloId], references: [id], onDelete: Cascade)

  @@map("cessioni_veicoli")
}

model PianoPagamento {
  id                 Int                   @id @default(autoincrement())
  operazioneId       Int                   @unique @map("operazione_id")
  societaId          Int                   @map("societa_id")
  tipo               TipoPianoPagamento
  stato              StatoPianoPagamento   @default(ATTIVO)
  numeroRate         Int?                  @map("numero_rate")
  importoRata        Decimal?              @map("importo_rata") @db.Decimal(10, 2)
  tan                Decimal?              @db.Decimal(5, 2)
  anticipo           Decimal?              @default(0) @db.Decimal(10, 2)
  frequenzaRate      FrequenzaRate         @default(MENSILE) @map("frequenza_rate")
  dataInizio         DateTime              @map("data_inizio") @db.Date
  dataChiusura       DateTime?             @map("data_chiusura") @db.Date
  motivoChiusura     MotivoChiusura?       @map("motivo_chiusura")
  penaleEstinzione   Decimal?              @map("penale_estinzione") @db.Decimal(10, 2)
  saldoResiduo       Decimal?              @map("saldo_residuo") @db.Decimal(10, 2)
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")

  operazione         Operazione            @relation(fields: [operazioneId], references: [id])
  societa            Societa               @relation(fields: [societaId], references: [id])
  pagamenti          Pagamento[]

  @@index([societaId])
  @@map("piani_pagamento")
}

model Pagamento {
  id                      Int               @id @default(autoincrement())
  pianoPagamentoId        Int               @map("piano_pagamento_id")
  numeroPagamento         Int               @map("numero_pagamento")
  data                    DateTime          @db.Date
  importo                 Decimal           @db.Decimal(10, 2)
  quotaCapitale           Decimal           @map("quota_capitale") @db.Decimal(10, 2)
  quotaInteressi          Decimal           @map("quota_interessi") @db.Decimal(10, 2)
  stato                   StatoPagamento    @default(PREVISTO)
  dataEffettivaPagamento  DateTime?         @map("data_effettiva_pagamento") @db.Date
  note                    String?           @db.Text
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime          @updatedAt @map("updated_at")

  pianoPagamento          PianoPagamento    @relation(fields: [pianoPagamentoId], references: [id], onDelete: Cascade)

  @@index([pianoPagamentoId, data, stato])
  @@index([data, stato])
  @@map("pagamenti")
}
