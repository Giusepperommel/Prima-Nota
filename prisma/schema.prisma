  CONTABILE
  GENERICA
  @@map("tipo_scadenza")
}

enum PrioritaScadenza {
  ALTA
  MEDIA
  BASSA
  @@map("priorita_scadenza")
}

enum TipoAlert {
  SCADENZA_IMMINENTE
  SCRITTURA_PROVVISORIA
  IVA_DA_LIQUIDARE
  BILANCIO_NON_QUADRA
  GENERICO
  @@map("tipo_alert")
}

enum LivelloAlert {
  INFO
  WARNING
  ERRORE
  @@map("livello_alert")
}

model UtenteAzienda {
  id              Int           @id @default(autoincrement())
  utenteId        Int           @map("utente_id")
  societaId       Int           @map("societa_id")
  ruolo           RuoloAzienda
  attivo          Boolean       @default(true)
  ultimoAccesso   DateTime?     @map("ultimo_accesso")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  utente          Utente        @relation(fields: [utenteId], references: [id])
  societa         Societa       @relation(fields: [societaId], references: [id])
  note            NotaAzienda[]

  @@unique([utenteId, societaId])
  @@index([utenteId])
  @@index([societaId])
  @@map("utenti_azienda")
}

model NotaAzienda {
  id                Int           @id @default(autoincrement())
  utenteAziendaId   Int           @map("utente_azienda_id")
  testo             String        @db.Text
  colore            String?       @db.VarChar(20)
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  utenteAzienda     UtenteAzienda @relation(fields: [utenteAziendaId], references: [id], onDelete: Cascade)

  @@index([utenteAziendaId])
  @@map("note_azienda")
}

model ScadenzaAzienda {
  id                  Int              @id @default(autoincrement())
  societaId           Int              @map("societa_id")
  createdByUtenteId   Int              @map("created_by_utente_id")
  descrizione         String           @db.VarChar(500)
  dataScadenza        DateTime         @db.Date @map("data_scadenza")
  completata          Boolean          @default(false)
  dataCompletamento   DateTime?        @map("data_completamento")
  tipoScadenza        TipoScadenza     @map("tipo_scadenza")
  priorita            PrioritaScadenza
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  societa             Societa          @relation(fields: [societaId], references: [id])
  createdBy           Utente           @relation("ScadenzeCreate", fields: [createdByUtenteId], references: [id])

  @@index([societaId, dataScadenza])
  @@index([societaId, completata])
  @@map("scadenze_azienda")
}

model AlertAzienda {
  id          Int           @id @default(autoincrement())
  societaId   Int           @map("societa_id")
  tipo        TipoAlert     @map("tipo")
  messaggio   String        @db.VarChar(500)
  livello     LivelloAlert
  letto       Boolean       @default(false)
  link        String?       @db.VarChar(255)
  createdAt   DateTime      @default(now()) @map("created_at")

  societa     Societa       @relation(fields: [societaId], references: [id])

  @@index([societaId, letto])
  @@index([societaId, createdAt])
  @@map("alert_azienda")
}

model InvitoAzienda {
  id                  Int           @id @default(autoincrement())
  societaId           Int           @map("societa_id")
  email               String        @db.VarChar(255)
  ruolo               RuoloAzienda
  token               String        @unique @db.VarChar(255)
  scadenza            DateTime
  accettato           Boolean       @default(false)
  createdByUtenteId   Int           @map("created_by_utente_id")
  createdAt           DateTime      @default(now()) @map("created_at")

  societa             Societa       @relation(fields: [societaId], references: [id])
  createdBy           Utente        @relation("InvitiCreate", fields: [createdByUtenteId], references: [id])

  @@unique([societaId, email])
  @@map("inviti_azienda")
}

// ─── Fatturazione Elettronica ────────────────────────────────────────────────

enum StatoFatturaElettronica {
  BOZZA
  GENERATA
  INVIATA
  CONSEGNATA
  SCARTATA
  MANCATA_CONSEGNA
  IMPOSSIBILITA_RECAPITO
  ANNULLATA

  @@map("stato_fattura_elettronica")
}

model FatturaElettronica {
  id                  Int                       @id @default(autoincrement()) @map("fattura_elettronica_id")
  societaId           Int                       @map("societa_id")
  operazioneId        Int                       @unique @map("operazione_id")
  sezionaleId         Int                       @map("sezionale_id")
  numero              String                    @db.VarChar(20)
  annoRiferimento     Int                       @map("anno_riferimento")
  progressivoFile     String                    @db.VarChar(5) @map("progressivo_file")
  nomeFile            String                    @db.VarChar(50) @map("nome_file")
  stato               StatoFatturaElettronica   @default(GENERATA)
  tipoDocumento       TipoDocumentoSdi          @map("tipo_documento")
  xmlContent          String                    @db.LongText @map("xml_content")
  xmlHash             String?                   @db.VarChar(64) @map("xml_hash")
  importoTotale       Decimal                   @db.Decimal(12, 2) @map("importo_totale")
  dataDocumento       DateTime                  @db.Date @map("data_documento")
  dataGenerazione     DateTime                  @default(now()) @map("data_generazione")
  dataInvio           DateTime?                 @map("data_invio")
  dataEsitoSdi        DateTime?                 @map("data_esito_sdi")
  identificativoSdi   String?                   @db.VarChar(50) @map("identificativo_sdi")
  erroriSdi           String?                   @db.Text @map("errori_sdi")
  createdByUserId     Int                       @map("created_by_user_id")
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")

  societa    Societa            @relation(fields: [societaId], references: [id])
  operazione Operazione         @relation(fields: [operazioneId], references: [id])
  sezionale  SezionaleFattura   @relation(fields: [sezionaleId], references: [id])
  createdBy  Utente             @relation(fields: [createdByUserId], references: [id])

  @@unique([societaId, sezionaleId, annoRiferimento, numero])
  @@unique([societaId, nomeFile])
  @@index([societaId, stato])
  @@index([societaId, annoRiferimento])
  @@map("fatture_elettroniche")
}

model SezionaleFattura {
  id              Int      @id @default(autoincrement()) @map("sezionale_id")
  societaId       Int      @map("societa_id")
  codice          String   @db.VarChar(10)
  descrizione     String   @db.VarChar(100)
  prefisso        String   @db.VarChar(10)
  separatore      String   @db.VarChar(5) @default("/")
  tipiDocumento   Json     @map("tipi_documento")
  ultimoNumero    Int      @default(0) @map("ultimo_numero")
  numeroIniziale  Int      @default(1) @map("numero_iniziale")
  annoCorrente    Int      @map("anno_corrente")
  formato         String   @db.VarChar(50) @default("{prefisso}{numero}")
  paddingCifre    Int      @default(1) @map("padding_cifre")
  attivo          Boolean  @default(true)
  predefinito     Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  societa             Societa              @relation(fields: [societaId], references: [id])
  fattureElettroniche FatturaElettronica[]

  @@unique([societaId, codice])
  @@index([societaId, attivo])
  @@map("sezionali_fattura")
}

model ConfigurazioneProvider {
  id              Int       @id @default(autoincrement()) @map("config_id")
  societaId       Int       @unique @map("societa_id")
  provider        String    @db.VarChar(30) @default("MANUALE")
  attivo          Boolean   @default(false)
  configurazione  Json?
  ultimoTest      DateTime? @map("ultimo_test")
  esitoTest       Boolean?  @map("esito_test")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  societa Societa @relation(fields: [societaId], references: [id])

  @@map("configurazione_provider")
}

// ─── Dichiarazioni Fiscali ───

model F24Versamento {
  id                Int       @id @default(autoincrement())
  societaId         Int       @map("societa_id")
  anno              Int
  mese              Int
  dataScadenza      DateTime  @map("data_scadenza") @db.Date
  dataPagamento     DateTime? @map("data_pagamento") @db.Date
  stato             StatoF24  @default(DA_PAGARE)
  totaleDebito      Decimal   @map("totale_debito") @db.Decimal(12, 2)
  totaleCredito     Decimal   @default(0) @map("totale_credito") @db.Decimal(12, 2)
  totaleVersamento  Decimal   @map("totale_versamento") @db.Decimal(12, 2)
  note              String?   @db.Text
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  societa Societa    @relation(fields: [societaId], references: [id])
  righe   F24Riga[]

  @@index([societaId, anno, mese])
  @@index([societaId, stato])
  @@map("f24_versamenti")
}

model F24Riga {
  id                  Int        @id @default(autoincrement())
  f24VersamentoId     Int        @map("f24_versamento_id")
  sezione             SezioneF24
  codiceTributo       String     @map("codice_tributo") @db.VarChar(10)
  rateazione          String?    @db.VarChar(4)
  annoRiferimento     Int        @map("anno_riferimento")
  periodoRiferimento  String?    @map("periodo_riferimento") @db.VarChar(4)
  importoDebito       Decimal    @default(0) @map("importo_debito") @db.Decimal(12, 2)
  importoCredito      Decimal    @default(0) @map("importo_credito") @db.Decimal(12, 2)
  descrizione         String?    @db.VarChar(255)

  f24Versamento F24Versamento @relation(fields: [f24VersamentoId], references: [id], onDelete: Cascade)

  @@map("f24_righe")
}

model CertificazioneUnica {
  id                Int       @id @default(autoincrement())
  societaId         Int       @map("societa_id")
  anno              Int
  anagraficaId      Int       @map("anagrafica_id")
  causaleCu         String    @map("causale_cu") @db.VarChar(2)
  ammontareLordo    Decimal   @map("ammontare_lordo") @db.Decimal(12, 2)
  imponibile        Decimal   @db.Decimal(12, 2)
  ritenutaAcconto   Decimal   @map("ritenuta_acconto") @db.Decimal(12, 2)
  rivalsaInps       Decimal   @default(0) @map("rivalsa_inps") @db.Decimal(12, 2)
  cassaPrevidenza   Decimal   @default(0) @map("cassa_previdenza") @db.Decimal(12, 2)
  stato             StatoCU   @default(BOZZA)
  dataGenerazione   DateTime? @map("data_generazione")
  dataInvio         DateTime? @map("data_invio")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  societa    Societa    @relation(fields: [societaId], references: [id])
  anagrafica Anagrafica @relation(fields: [anagraficaId], references: [id])

  @@unique([societaId, anno, anagraficaId])
  @@index([societaId, anno])
  @@map("certificazioni_uniche")
}

model DichiarazioneFiscale {
  id               Int                @id @default(autoincrement())
  societaId        Int                @map("societa_id")
  anno             Int
  tipo             TipoDichiarazione
  stato            StatoDichiarazione @default(NON_INIZIATA)
  datiCalcolo      Json?              @map("dati_calcolo")
  dataGenerazione  DateTime?          @map("data_generazione")
  dataInvio        DateTime?          @map("data_invio")
  note             String?            @db.Text
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  societa Societa @relation(fields: [societaId], references: [id])

  @@unique([societaId, anno, tipo])
  @@index([societaId, anno])
  @@map("dichiarazioni_fiscali")
}

enum StatoF24 {
  DA_PAGARE
  PAGATO
  SCADUTO
  @@map("stato_f24")
}

enum SezioneF24 {
  ERARIO
  INPS
  REGIONI_ENTI_LOCALI
  @@map("sezione_f24")
}

enum StatoCU {
  BOZZA
  GENERATA
  INVIATA
  @@map("stato_cu")
}

enum TipoDichiarazione {
  REDDITI_SC
  IRAP
  MOD_770
  @@map("tipo_dichiarazione")
}

enum StatoDichiarazione {
  NON_INIZIATA
  IN_PREPARAZIONE
  GENERATA
  INVIATA
  @@map("stato_dichiarazione")
}
